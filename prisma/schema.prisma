datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
}

enum StatusLeitura {
  quero_ler
  lendo
  lido
  abandonado
}

model Livro {
  id                String        @id @default(uuid())
  usuario_id        String
  google_book_id    String?       @unique
  titulo            String
  autores           String[]
  capa_url          String?
  status            StatusLeitura @default(quero_ler)
  data_adicionado   DateTime      @default(now())
  data_finalizacao  DateTime?
  user              Usuario     @relation(fields: [usuario_id], references: [id])

  @@map("livros")
}

model Usuario{
  id                String        @id @default(uuid())
  nome              String
  email             String        @unique
  foto_url          String?
  senha             String
  livros            Livro[]
  
  @@map("usuarios")
}